#! This is a sample .env file. Copy this to .env and fill in the values.

# Project Environment
ENVIRONMENT="development"

# Database
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="my_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password@123"

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Password Hashhing (Argon2id)
PASSWORD_TIME_COST=2
PASSWORD_MEMORY_COST=65536
PASSWORD_PARALLELISM=4
PASSWORD_HASH_LENGTH=32
PASSWORD_SALT_LENGTH=16

# JWT
JWT_SECRET_KEY="YOUR_JWT_SECRET_KEY"  # Recreate this; use "opensll rand -hex 32"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=null
JWT_AUDIENCE=null
JWT_LEEWAY_SECONDS=0

# Cookie
COOKIE_SECURE=false # true in staging/production
COOKIE_SAMESITE="lax"  # strict | lax | none
COOKIE_DOMAIN=  # leave blank for current domain, or set e.g. example.com
COOKIE_ACCESS_TOKEN="ACCESS_TOKEN"
COOKIE_REFRESH_TOKEN="REFRESH_TOKEN"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD="password@123"
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_DECODE_RESPONSES=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Redis Key Prefixes
REDIS_TOKEN_REVOKE_PREFIX="TOKEN_REVOKED"

# Redis Commander
REDIS_COMMANDER_PORT=8081

# PGAdmin
PGADMIN_DEFAULT_EMAIL="admin@admin.com"
PGADMIN_DEFAULT_PASSWORD="admin"
PGADMIN_PORT=5050